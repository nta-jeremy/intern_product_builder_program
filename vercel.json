{
  "installCommand": "npm install",
  "buildCommand": "npm run build:vite",
  "outputDirectory": "dist",
  "framework": null,
  "redirects": [
    {
      "source": "/intro",
      "destination": "/intro/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}